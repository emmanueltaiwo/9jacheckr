# ── SERVER (apps/server/.env) ──────────────────────────────────────────────────

PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/naija-checkr

# Public URL of the Express API (where /api/auth/* is served)
# Dev:  http://localhost:4000
# Prod: https://api.9jacheckr.xyz
BETTER_AUTH_URL=http://localhost:4000

# Web app origin — used for CORS and trusted OAuth redirects
# Dev:  http://localhost:3000
# Prod: https://www.9jacheckr.xyz
WEB_APP_URL=http://localhost:3000

# Shared secret — must be the same on server and web if you ever need to
# validate sessions server-side; keep it long and random
BETTER_AUTH_SECRET=your-secret-here

# Cookie domain for cross-subdomain sharing
# Dev:  leave blank (host-only cookie works for localhost)
# Prod: .9jacheckr.xyz
AUTH_COOKIE_DOMAIN=

# Google OAuth — https://console.cloud.google.com
# Add redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

API_KEY_SECRET=your-api-key-hmac-secret
BOT_INTERNAL_TOKEN=your-bot-token

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=60

# ── WEB (apps/web/.env.local) ──────────────────────────────────────────────────

# The Express API base — no trailing slash
# Dev:  http://localhost:4000
# Prod: https://api.9jacheckr.xyz
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# Same as BETTER_AUTH_URL — the auth client points here
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:4000
